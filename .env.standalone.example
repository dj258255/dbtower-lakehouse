# 셀프호스트 어플라이언스 환경 (ROADMAP 11단계).
#   cp .env.standalone.example .env   후 아래 시크릿을 채운다.
# 데모(내 DBTower 없이 체험): 이 파일 그대로 두고
#   docker compose -f docker-compose.standalone.yml --profile demo up -d
# 프로덕션: 아래 "원천" 절을 자기 DBTower 메타 PG로 바꾼다.

# ─────────────────────────────────────────────────────────────
# 시크릿 — 반드시 새로 생성한다(기본값 없음, 미설정 시 기동 거부).
# ─────────────────────────────────────────────────────────────
# Airflow 커넥션 암호화 키:  python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AIRFLOW_FERNET_KEY=
# Airflow 웹 세션 서명 키:   openssl rand -hex 32
AIRFLOW_WEBSERVER_SECRET_KEY=
# Airflow 메타 DB 비밀번호:  openssl rand -hex 16
AIRFLOW_META_PASSWORD=
# DuckLake 카탈로그 + Metabase 앱 DB(번들 PG) 비밀번호: openssl rand -hex 16
CATALOG_PASSWORD=
# 번들 MinIO 루트 계정
MINIO_ROOT_USER=lakehouse
MINIO_ROOT_PASSWORD=

# Airflow 관리자(웹 UI 로그인)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=admin@lakehouse.local

# ─────────────────────────────────────────────────────────────
# 원천 — 프로덕션에서만 채운다. 데모는 비워두면 샘플 원천으로 폴백.
# CONTRACT §1: query_snapshot + database_instance 두 테이블에 read-only 권한 필요.
#   CREATE ROLE lakehouse_reader LOGIN PASSWORD '...';
#   GRANT CONNECT ON DATABASE <메타DB> TO lakehouse_reader;
#   GRANT USAGE ON SCHEMA public TO lakehouse_reader;
#   GRANT SELECT ON query_snapshot, database_instance TO lakehouse_reader;
# ⚠️ database_instance 권한이 빠지면 인스턴스 0개로 판정돼 "조용히 빈 결과"가 난다.
#SRC_PG_HOST=your-dbtower-postgres
#SRC_PG_PORT=5432
#SRC_PG_DB=dbtower
#SRC_PG_USER=lakehouse_reader
#SRC_PG_PASSWORD=

# ─────────────────────────────────────────────────────────────
# 노브(ROADMAP 12단계) — 규모에 맞춰 조정. 수백 대면 PARALLELISM을 올린다.
# ─────────────────────────────────────────────────────────────
AIRFLOW_PARALLELISM=4
DUCKLAKE_RETENTION=7 days
# 실패 알림 webhook(비우면 알림 없이 돈다). 컨테이너 관점 주소.
ALERT_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────
# 포트 — 다른 스택과 병행 기동 시 충돌하면 바꾼다(기본은 표준 포트).
# ─────────────────────────────────────────────────────────────
AIRFLOW_PORT=8080
METABASE_PORT=3000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

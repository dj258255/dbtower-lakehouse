# 로컬 e2e(호스트 직접 실행) 기본값. 실제 값이 노출돼도 데모 스택 로컬 크리덴셜이다.
# 복사: cp .env.example .env

# --- 원천: DBTower 메타 PG (관측 전용, 읽기 전용) ---
# 호스트에서 직접 실행 시. Airflow 컨테이너 안에서는 docker-compose가
# SRC_PG_HOST=dbtower-postgres / SRC_PG_PORT=5432 로 덮어쓴다.
SRC_PG_HOST=localhost
SRC_PG_PORT=15432
SRC_PG_DB=dbtower
SRC_PG_USER=postgres
SRC_PG_PASSWORD=dbtower1234

# --- 적재: MinIO(S3 호환), dbtower-minio 재사용 ---
S3_ENDPOINT=http://localhost:19000
S3_ACCESS_KEY=dbtower
S3_SECRET_KEY=dbtower1234
S3_BUCKET=lakehouse
S3_REGION=us-east-1

# 추출 배치 크기(서버커서 itersize).
EXTRACT_FETCH_BATCH=50000

# --- 테이블 포맷: DuckLake (Phase 5) ---
# 카탈로그는 기본적으로 SRC_PG_* 와 같은 PG 인스턴스의 별도 DB. DBTower 메타 DB(dbtower)와 분리.
# 데이터 파일은 위 S3(MinIO)에 둔다.
DUCKLAKE_CATALOG_DB=ducklake_catalog
DUCKLAKE_DATA_PATH=s3://lakehouse/ducklake/

# (선택) 카탈로그 PG를 원천과 다른 인스턴스에 둘 때만 채운다 — 11단계 standalone
# 어플라이언스용(원천=외부 DBTower, 카탈로그=번들 PG). 미지정 시 SRC_PG_* 를 재사용한다.
#DUCKLAKE_CATALOG_HOST=
#DUCKLAKE_CATALOG_PORT=
#DUCKLAKE_CATALOG_USER=
#DUCKLAKE_CATALOG_PASSWORD=

# --- 운영 경화 (Phase 6) ---
# 실패 알림 webhook — 태스크 최종 실패 시 이 URL로 JSON POST. 비우면 알림 없이 돈다.
# 컨테이너 관점 주소로 쓸 것(호스트 수신기면 host.docker.internal).
ALERT_WEBHOOK_URL=
# DuckLake 스냅샷·파일 보존 기간(주간 CHECKPOINT의 만료 기준).
DUCKLAKE_RETENTION=7 days

# Airflow 컨테이너용(호스트 UID 매핑, 로그 권한).
AIRFLOW_UID=50000

# --- 대시보드: Metabase (Phase 7) ---
# 초기 설정 스크립트(scripts/metabase_bootstrap.py)가 쓰는 데모 관리자 계정.
# 비밀번호는 직접 강한 값으로 채울 것(Metabase 정책: 대소문자+숫자 포함).
METABASE_URL=http://localhost:13001
METABASE_ADMIN_EMAIL=admin@dbtower.local
METABASE_ADMIN_PASSWORD=change-me-Strong1
